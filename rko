<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ПартнёрРКО — зарабатывай на каждом клиенте</title>
<meta name="description" content="Партнёрская программа РКО. Приводи бизнес в банки-партнёры и получай до 8000 ₽ за каждого клиента. Без потолка, без бюрократии.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Onest:wght@400;500;700;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ============================================================
   TOKENS
   ============================================================ */
:root {
  --c-bg:          #0A0A0A;
  --c-surface:     #111111;
  --c-surface-2:   #161616;
  --c-border:      rgba(255,255,255,0.07);
  --c-border-md:   rgba(255,255,255,0.13);
  --c-border-hi:   rgba(255,255,255,0.2);
  --c-text:        #F0EDE8;
  --c-muted:       #6E6B67;
  --c-muted-hi:    #9C9993;
  --c-accent:      #C8FF00;
  --c-accent-dim:  rgba(200,255,0,0.10);
  --c-accent-glow: rgba(200,255,0,0.25);
  --c-ink:         #0A0A0A;
  --ff:            'Onest', sans-serif;
  --ff-mono:       'JetBrains Mono', monospace;
  --radius:        12px;
  --radius-lg:     20px;
}

/* ============================================================
   RESET
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  background: var(--c-bg);
  color: var(--c-text);
  font-family: var(--ff);
  line-height: 1.65;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
img { display: block; max-width: 100%; }
a { color: inherit; text-decoration: none; }
button { font-family: var(--ff); cursor: pointer; }

/* ============================================================
   UTILITIES
   ============================================================ */
.container { max-width: 1120px; margin: 0 auto; padding: 0 28px; }

.mono {
  font-family: var(--ff-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-accent);
}

.section-label { margin-bottom: 18px; }

.section-title {
  font-size: clamp(32px, 4.5vw, 54px);
  font-weight: 900;
  letter-spacing: -0.035em;
  line-height: 1.05;
  margin-bottom: 18px;
}

.section-sub {
  font-size: 18px;
  color: var(--c-muted-hi);
  line-height: 1.65;
  max-width: 560px;
}

/* ============================================================
   SCROLL REVEAL
   ============================================================ */
.reveal {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.65s cubic-bezier(.22,1,.36,1),
              transform 0.65s cubic-bezier(.22,1,.36,1);
}
.reveal.visible { opacity: 1; transform: none; }
.reveal-d1 { transition-delay: 0.1s; }
.reveal-d2 { transition-delay: 0.2s; }
.reveal-d3 { transition-delay: 0.3s; }
.reveal-d4 { transition-delay: 0.4s; }

@media (prefers-reduced-motion: reduce) {
  .reveal { opacity: 1; transform: none; transition: none; }
}

/* ============================================================
   NAV
   ============================================================ */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 64px;
  display: flex; align-items: center;
  background: rgba(10,10,10,0.80);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--c-border);
  transition: background 0.3s;
}
.nav-inner {
  width: 100%; max-width: 1120px; margin: 0 auto;
  padding: 0 28px;
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  font-size: 17px; font-weight: 900; letter-spacing: -0.04em;
  display: flex; align-items: center; gap: 2px;
}
.nav-logo em { font-style: normal; color: var(--c-accent); }
.nav-links {
  display: flex; gap: 36px; align-items: center;
}
.nav-links a {
  font-size: 14px; color: var(--c-muted);
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--c-text); }
.nav-cta {
  background: var(--c-accent);
  color: var(--c-ink);
  padding: 9px 22px;
  border-radius: 8px;
  font-weight: 800;
  font-size: 14px;
  transition: opacity 0.2s, transform 0.15s;
  border: none;
  display: inline-block;
}
.nav-cta:hover { opacity: 0.88; transform: translateY(-1px); }

/* Hamburger */
.nav-burger {
  display: none;
  flex-direction: column; gap: 5px;
  background: none; border: none;
  padding: 4px;
}
.nav-burger span {
  display: block; width: 22px; height: 2px;
  background: var(--c-text); border-radius: 2px;
  transition: transform 0.2s, opacity 0.2s;
}
.nav-burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.open span:nth-child(2) { opacity: 0; }
.nav-burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-menu {
  display: none;
  position: fixed; top: 64px; left: 0; right: 0; z-index: 190;
  background: rgba(10,10,10,0.97);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--c-border);
  padding: 24px 28px 32px;
  flex-direction: column; gap: 20px;
}
.mobile-menu.open { display: flex; }
.mobile-menu a { font-size: 18px; color: var(--c-muted-hi); font-weight: 600; }
.mobile-menu a:hover { color: var(--c-text); }
.mobile-menu .nav-cta { align-self: flex-start; margin-top: 8px; }

/* ============================================================
   HERO
   ============================================================ */
.hero {
  padding: 160px 28px 100px;
  max-width: 1120px; margin: 0 auto;
  position: relative;
}

/* Ambient glow behind hero */
.hero::before {
  content: '';
  position: absolute; top: 80px; left: -100px;
  width: 700px; height: 500px;
  background: radial-gradient(ellipse at 30% 40%, rgba(200,255,0,0.055) 0%, transparent 65%);
  pointer-events: none;
}

.hero-tag {
  display: inline-flex; align-items: center; gap: 10px;
  background: var(--c-accent-dim);
  border: 1px solid rgba(200,255,0,0.22);
  color: var(--c-accent);
  font-family: var(--ff-mono);
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.10em; text-transform: uppercase;
  padding: 7px 16px; border-radius: 100px;
  margin-bottom: 36px;
}
.hero-tag-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--c-accent);
  animation: blink 2.2s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.25; }
}

.hero h1 {
  font-size: clamp(48px, 7.5vw, 96px);
  font-weight: 900;
  line-height: 1.0;
  letter-spacing: -0.045em;
  margin-bottom: 28px;
  max-width: 880px;
}
.hero h1 em { font-style: normal; color: var(--c-accent); }

.hero-sub {
  font-size: clamp(17px, 1.8vw, 21px);
  color: var(--c-muted-hi);
  max-width: 560px;
  line-height: 1.6;
  margin-bottom: 52px;
}

.hero-btns { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

.btn-primary {
  background: var(--c-accent);
  color: var(--c-ink);
  padding: 17px 38px;
  border-radius: 10px;
  font-weight: 900; font-size: 16px;
  border: none;
  display: inline-block;
  transition: transform 0.15s ease, opacity 0.15s ease, box-shadow 0.2s ease;
  box-shadow: 0 0 0 0 var(--c-accent-glow);
  cursor: pointer;
}
.btn-primary:hover {
  transform: translateY(-3px);
  opacity: 0.9;
  box-shadow: 0 8px 32px var(--c-accent-glow);
}
.btn-primary:active { transform: translateY(0); }

.btn-secondary {
  background: transparent;
  color: var(--c-muted-hi);
  font-size: 14px;
  border: 1px solid var(--c-border-md);
  padding: 16px 28px;
  border-radius: 10px;
  display: inline-block;
  transition: border-color 0.2s, color 0.2s;
}
.btn-secondary:hover { border-color: var(--c-border-hi); color: var(--c-text); }

.hero-stats {
  display: flex; gap: 0;
  margin-top: 88px;
  padding-top: 52px;
  border-top: 1px solid var(--c-border);
  flex-wrap: wrap;
}
.hero-stat {
  flex: 1; min-width: 160px;
  padding-right: 40px;
  border-right: 1px solid var(--c-border);
  margin-bottom: 24px;
}
.hero-stat:last-child { border-right: none; }
.hero-stat-num {
  font-family: var(--ff-mono);
  font-size: clamp(30px, 3.5vw, 46px);
  font-weight: 500;
  color: var(--c-text);
  letter-spacing: -0.02em;
  line-height: 1.1;
}
.hero-stat-num em { font-style: normal; color: var(--c-accent); }
.hero-stat-label {
  font-size: 13px; color: var(--c-muted);
  margin-top: 6px; line-height: 1.4;
}

/* ============================================================
   SECTION: HOW IT WORKS
   ============================================================ */
.section-how { padding: 110px 28px; }
.section-how .container {}

.steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  margin-top: 64px;
  background: var(--c-border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.step {
  background: var(--c-surface);
  padding: 40px 32px;
  transition: background 0.25s;
  position: relative;
}
.step::after {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--c-accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.35s cubic-bezier(.22,1,.36,1);
}
.step:hover { background: var(--c-surface-2); }
.step:hover::after { transform: scaleX(1); }

.step-num {
  font-family: var(--ff-mono);
  font-size: 11px; letter-spacing: 0.12em;
  color: var(--c-accent);
  margin-bottom: 22px;
}
.step-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  background: var(--c-accent-dim);
  border: 1px solid rgba(200,255,0,0.18);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
  margin-bottom: 22px;
}
.step h3 {
  font-size: 17px; font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 10px;
}
.step p { font-size: 14px; color: var(--c-muted); line-height: 1.65; }

/* ============================================================
   SECTION: RATES
   ============================================================ */
.section-rates {
  padding: 110px 28px;
  background: var(--c-surface);
  border-top: 1px solid var(--c-border);
  border-bottom: 1px solid var(--c-border);
}

.rates-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 64px;
}

.rate-card {
  background: var(--c-bg);
  border: 1px solid var(--c-border-md);
  border-radius: var(--radius-lg);
  padding: 32px;
  position: relative;
  transition: border-color 0.25s, transform 0.25s;
}
.rate-card:hover {
  border-color: var(--c-border-hi);
  transform: translateY(-5px);
}
.rate-card.featured {
  border-color: rgba(200,255,0,0.30);
  background: #0C1100;
}
.rate-card.featured:hover { border-color: rgba(200,255,0,0.55); }

.rate-badge {
  position: absolute; top: -13px; left: 24px;
  background: var(--c-accent); color: var(--c-ink);
  font-family: var(--ff-mono);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.10em; text-transform: uppercase;
  padding: 5px 14px; border-radius: 100px;
}

.rate-bank {
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--c-muted);
  margin-bottom: 6px;
}
.rate-product {
  font-size: 19px; font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 28px;
  line-height: 1.25;
}

.rate-amount {
  font-family: var(--ff-mono);
  font-size: 48px; font-weight: 500;
  color: var(--c-accent);
  letter-spacing: -0.025em;
  line-height: 1;
  display: flex; align-items: baseline; gap: 6px;
}
.rate-amount-cur {
  font-size: 20px; color: var(--c-muted);
}

.rate-desc {
  font-size: 13px; color: var(--c-muted);
  margin-top: 14px;
  line-height: 1.6;
  min-height: 52px;
}

.rate-divider {
  height: 1px; background: var(--c-border);
  margin: 20px 0;
}

.rate-tags { display: flex; gap: 6px; flex-wrap: wrap; }
.tag {
  background: rgba(255,255,255,0.05);
  color: var(--c-muted);
  font-size: 11px; font-weight: 500;
  padding: 5px 12px; border-radius: 100px;
  letter-spacing: 0.04em;
  border: 1px solid var(--c-border);
}

/* ============================================================
   SECTION: CALCULATOR
   ============================================================ */
.section-calc { padding: 110px 28px; }

.calc-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
  margin-top: 64px;
}

.calc-controls { display: flex; flex-direction: column; gap: 36px; }

.control-group {}
.control-header {
  display: flex; justify-content: space-between; align-items: baseline;
  margin-bottom: 14px;
}
.control-header label {
  font-size: 14px; color: var(--c-muted-hi);
}
.control-val {
  font-family: var(--ff-mono);
  font-size: 14px; font-weight: 500;
  color: var(--c-accent);
}

/* Custom range */
input[type="range"] {
  width: 100%;
  -webkit-appearance: none; appearance: none;
  height: 3px;
  background: var(--c-border-md);
  border-radius: 2px;
  outline: none; cursor: pointer;
}
input[type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none; appearance: none;
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--c-accent);
  border: 3px solid var(--c-bg);
  box-shadow: 0 0 0 2px var(--c-accent);
  cursor: pointer;
  transition: transform 0.15s;
}
input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.15); }
input[type="range"]::-moz-range-thumb {
  width: 22px; height: 22px; border-radius: 50%;
  background: var(--c-accent);
  border: 3px solid var(--c-bg);
  cursor: pointer;
}

.calc-results { display: flex; flex-direction: column; gap: 14px; }

.result-main {
  background: #0C1100;
  border: 1px solid rgba(200,255,0,0.28);
  border-radius: var(--radius-lg);
  padding: 36px;
}
.result-main-label {
  font-size: 13px; color: var(--c-muted); margin-bottom: 10px;
}
.result-main-val {
  font-family: var(--ff-mono);
  font-size: clamp(36px, 4vw, 56px);
  font-weight: 500; color: var(--c-accent);
  letter-spacing: -0.025em;
  line-height: 1;
}

.result-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

.result-card {
  background: var(--c-surface);
  border: 1px solid var(--c-border-md);
  border-radius: var(--radius);
  padding: 24px;
}
.result-card-label {
  font-size: 12px; color: var(--c-muted);
  margin-bottom: 8px;
}
.result-card-val {
  font-family: var(--ff-mono);
  font-size: 22px; font-weight: 500;
  color: var(--c-text);
  letter-spacing: -0.02em;
}

/* ============================================================
   SECTION: TRAFFIC
   ============================================================ */
.section-traffic { padding: 110px 28px; }

.traffic-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 64px;
}

.traffic-card {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-lg);
  padding: 32px;
  transition: border-color 0.25s, transform 0.25s;
}
.traffic-card:hover {
  border-color: var(--c-border-md);
  transform: translateY(-3px);
}

.traffic-icon-wrap {
  width: 52px; height: 52px;
  border-radius: 14px;
  background: var(--c-surface-2);
  border: 1px solid var(--c-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 24px;
  margin-bottom: 24px;
}

.traffic-card h4 {
  font-size: 16px; font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 10px;
}
.traffic-card p { font-size: 14px; color: var(--c-muted); line-height: 1.65; }

.traffic-badge {
  display: inline-block;
  background: var(--c-accent-dim);
  color: var(--c-accent);
  font-family: var(--ff-mono);
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 6px;
  margin-top: 16px;
}

/* ============================================================
   SECTION: WHY US
   ============================================================ */
.section-why {
  padding: 110px 28px;
  background: var(--c-surface);
  border-top: 1px solid var(--c-border);
  border-bottom: 1px solid var(--c-border);
}

.why-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
  margin-top: 64px;
}

.why-card {
  background: var(--c-bg);
  border: 1px solid var(--c-border-md);
  border-radius: var(--radius-lg);
  padding: 40px;
  display: flex; gap: 24px; align-items: flex-start;
  transition: border-color 0.25s;
}
.why-card:hover { border-color: var(--c-border-hi); }
.why-num {
  font-family: var(--ff-mono);
  font-size: 36px; font-weight: 500;
  color: var(--c-accent);
  letter-spacing: -0.03em;
  line-height: 1;
  flex-shrink: 0;
  min-width: 52px;
}
.why-text h4 {
  font-size: 17px; font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}
.why-text p { font-size: 14px; color: var(--c-muted); line-height: 1.65; }

/* ============================================================
   SECTION: CTA / FORM
   ============================================================ */
.section-cta {
  padding: 110px 28px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.section-cta::before {
  content: '';
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 800px; height: 800px;
  background: radial-gradient(circle, rgba(200,255,0,0.055) 0%, transparent 65%);
  pointer-events: none;
}

.cta-title {
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 900;
  letter-spacing: -0.04em;
  line-height: 1.05;
  max-width: 720px;
  margin: 0 auto 24px;
}
.cta-title em { font-style: normal; color: var(--c-accent); }

.cta-sub {
  font-size: 18px;
  color: var(--c-muted-hi);
  max-width: 480px;
  margin: 0 auto 48px;
  line-height: 1.6;
}

.cta-form {
  display: flex; gap: 12px;
  max-width: 500px; margin: 0 auto;
  flex-wrap: wrap; justify-content: center;
}

.cta-input {
  flex: 1; min-width: 220px;
  background: var(--c-surface);
  border: 1px solid var(--c-border-md);
  border-radius: 10px;
  color: var(--c-text);
  font-family: var(--ff);
  font-size: 16px;
  padding: 16px 20px;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.cta-input:focus {
  border-color: rgba(200,255,0,0.45);
  box-shadow: 0 0 0 3px rgba(200,255,0,0.10);
}
.cta-input::placeholder { color: var(--c-muted); }
.cta-input.error { border-color: rgba(255,80,80,0.5); }

.cta-note {
  font-size: 13px; color: var(--c-muted);
  margin-top: 18px;
}

.success-block {
  display: none;
  background: var(--c-accent-dim);
  border: 1px solid rgba(200,255,0,0.28);
  border-radius: 12px;
  padding: 20px 32px;
  color: var(--c-accent);
  font-weight: 700; font-size: 16px;
  max-width: 440px; margin: 0 auto;
  text-align: center;
}
.success-block.show { display: block; }

/* ============================================================
   SECTION: FAQ
   ============================================================ */
.section-faq { padding: 110px 28px; }
.section-faq .inner { max-width: 800px; margin: 0 auto; }

.faq-list { margin-top: 56px; }

.faq-item {
  border-bottom: 1px solid var(--c-border);
}
.faq-btn {
  width: 100%; background: none; border: none;
  color: var(--c-text); font-family: var(--ff);
  font-size: 16px; font-weight: 600;
  text-align: left;
  padding: 24px 0;
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 20px;
  cursor: pointer;
  transition: color 0.2s;
}
.faq-btn:hover { color: var(--c-accent); }
.faq-icon {
  font-size: 20px; font-weight: 300;
  color: var(--c-muted); flex-shrink: 0;
  line-height: 1.3;
  transition: transform 0.25s ease, color 0.2s;
  display: block;
}
.faq-item.open .faq-icon {
  transform: rotate(45deg);
  color: var(--c-accent);
}
.faq-answer {
  display: none;
  padding: 0 48px 24px 0;
  font-size: 15px; color: var(--c-muted-hi);
  line-height: 1.75;
}
